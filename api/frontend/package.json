{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "pre-commit": "pnpm deps && pnpm type-check && pnpm lint && pnpm format",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "deps": "pnpm i && pnpm audit && pnpm declutter",
    "format": "prettier --write .",
    "type-check": "vue-tsc --declaration --emitDeclarationOnly",
    "declutter": "knip --no-exit-code",
    "test": "vitest --dom --reporter verbose",
    "test:once": "vitest --run --coverage --dom",
    "coverage": "vitest --coverage --dom",
    "test-ui": "vitest --ui",
    "openapi": "openapi-generator-cli --openapitools .openapitools.json generate"
  },
  "pnpm": {
    "overrides": {},
    "auditConfig": {
      "ignoreGhsas": []
    }
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.19",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.2",
    "sweetalert2": "^11.26.24",
    "tailwindcss": "^4.2.2",
    "uuid": "^14.0.0",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-standard-with-typescript": "^9.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.5.0",
    "msw": "2.13.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  }
}
